{
  "name": "ainovel-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test ./tests/**/*.test.ts",
    "test:smoke": "tsx ./scripts/smoke-sprint3.ts",

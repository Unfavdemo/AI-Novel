    "db:seed": "node --import tsx --env-file=.env ./scripts/seed-sample-books.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
